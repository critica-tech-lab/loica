# --- Required ---
NODE_ENV=development
PORT=3000
SECURE_COOKIE=true

# WebSocket URL as seen by the browser. Optional — if unset, it is derived:
#  - behind a TLS proxy (X-Forwarded-Proto / SITE_URL): wss://<host><WS_PATH>
#  - direct / local dev:                                ws://<host>:<WS_PORT>
WS_URL=wss://your-domain.com/ws
WS_PATH=/ws             # path the reverse proxy routes to the WS server (default /ws)
WS_PORT=4001            # default: 4001 (standalone WS server port, direct/dev)
WS_HOST=127.0.0.1       # default: 127.0.0.1 in production, 0.0.0.0 in dev
ALLOWED_ORIGINS=https://your-domain.com   # comma-separated, optional

# --- Email ---
# Transport is picked in order: SMTP (if SMTP_HOST set) → Mailgun API → console stub.
# EMAIL_FROM applies to whichever transport is used (falls back to MAILGUN_FROM).
EMAIL_FROM=noreply@example.com

# Option 1: SMTP (any provider — Mailgun SMTP, Postfix, Gmail, a mail addon, …)
SMTP_HOST=
SMTP_PORT=587           # 465 implies implicit TLS; 587/25 use STARTTLS
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=            # "true" to force implicit TLS (auto-on for port 465)

# Option 2: Mailgun REST API (used only if SMTP_HOST is empty)
# --- Auth (optional) ---
# Hard floor over the admin settings UI. For an SSO-only install (see OIDC),
# DISABLE_LOCAL_LOGIN=true turns off password login AND signup. REGISTRATION_OPEN=false
# closes new signups while keeping local login working.
DISABLE_LOCAL_LOGIN=
REGISTRATION_OPEN=

# --- Mailgun (optional, emails are console.log'd without this) ---
MAILGUN_API_KEY=
MAILGUN_DOMAIN=m.example.com
MAILGUN_FROM=noreply@m.example.com
MAILGUN_REGION=eu

# --- OIDC single sign-on (optional) ---
# Generic OpenID Connect login. Ships as an extension, disabled by default —
# enable "oidc" from the admin panel, then set these. Works with any compliant
# IdP (Authentik, Keycloak, Google, …). CLOUDRON_OIDC_* equivalents also work.
# Register the redirect URI <your-site>/auth/oidc/callback at your IdP.
OIDC_ISSUER=                       # e.g. https://idp.example.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid email profile   # optional, this is the default
OIDC_LABEL=Sign in with SSO        # optional, button label on the login page
