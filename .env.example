# --- Required ---
NODE_ENV=development
PORT=3000
SECURE_COOKIE=true

# WebSocket server URL (as seen by the browser)
WS_URL=wss://your-domain.com/ws
WS_PORT=4001            # default: 4001
WS_HOST=127.0.0.1       # default: 127.0.0.1 in production, 0.0.0.0 in dev
ALLOWED_ORIGINS=https://your-domain.com   # comma-separated, optional

# --- Mailgun (optional, emails are console.log'd without this) ---
MAILGUN_API_KEY=
MAILGUN_DOMAIN=m.example.com
MAILGUN_FROM=noreply@m.example.com
MAILGUN_REGION=eu

# --- OIDC single sign-on (optional) ---
# Generic OpenID Connect login. Ships as an extension, disabled by default —
# enable "oidc" from the admin panel, then set these. Works with any compliant
# IdP (Authentik, Keycloak, Google, …). CLOUDRON_OIDC_* equivalents also work.
# Register the redirect URI <your-site>/auth/oidc/callback at your IdP.
OIDC_ISSUER=                       # e.g. https://idp.example.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid email profile   # optional, this is the default
OIDC_LABEL=Sign in with SSO        # optional, button label on the login page
