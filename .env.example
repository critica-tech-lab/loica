# --- Required ---
NODE_ENV=development
PORT=3000
SECURE_COOKIE=true

# WebSocket server URL (as seen by the browser)
WS_URL=wss://your-domain.com/ws
WS_PORT=4001            # default: 4001
WS_HOST=127.0.0.1       # default: 127.0.0.1 in production, 0.0.0.0 in dev
ALLOWED_ORIGINS=https://your-domain.com   # comma-separated, optional

# --- Email ---
# Transport is picked in order: SMTP (if SMTP_HOST set) → Mailgun API → console stub.
# EMAIL_FROM applies to whichever transport is used (falls back to MAILGUN_FROM).
EMAIL_FROM=noreply@example.com

# Option 1: SMTP (any provider — Mailgun SMTP, Postfix, Gmail, a mail addon, …)
SMTP_HOST=
SMTP_PORT=587           # 465 implies implicit TLS; 587/25 use STARTTLS
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=            # "true" to force implicit TLS (auto-on for port 465)

# Option 2: Mailgun REST API (used only if SMTP_HOST is empty)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=m.example.com
MAILGUN_FROM=noreply@m.example.com
MAILGUN_REGION=eu
