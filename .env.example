# --- Required ---
NODE_ENV=development
PORT=3000
SECURE_COOKIE=true

# WebSocket URL as seen by the browser. Optional — if unset, it is derived:
#  - behind a TLS proxy (X-Forwarded-Proto / SITE_URL): wss://<host><WS_PATH>
#  - direct / local dev:                                ws://<host>:<WS_PORT>
WS_URL=wss://your-domain.com/ws
WS_PATH=/ws             # path the reverse proxy routes to the WS server (default /ws)
WS_PORT=4001            # default: 4001 (standalone WS server port, direct/dev)
WS_HOST=127.0.0.1       # default: 127.0.0.1 in production, 0.0.0.0 in dev
ALLOWED_ORIGINS=https://your-domain.com   # comma-separated, optional

# --- Mailgun (optional, emails are console.log'd without this) ---
MAILGUN_API_KEY=
MAILGUN_DOMAIN=m.example.com
MAILGUN_FROM=noreply@m.example.com
MAILGUN_REGION=eu
