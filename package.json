{
  "name": "loica",
  "private": true,
  "type": "module",
  "description": "Self-hosted collaborative Markdown editor with real-time sync, workspaces, and an extension system.",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/critica-tech-lab/loica",
  "repository": {
    "type": "git",
    "url": "https://github.com/critica-tech-lab/loica.git"
  },
  "scripts": {
    "dev": "react-router dev",
    "dev:all": "bun run dev & bun run ws & wait",
    "stop": "pkill -f 'ws-server.ts' || true; pkill -f 'react-router dev' || true",
    "ws": "node ws-server.ts",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "restart": "fuser -k 4000/tcp 2>/dev/null; fuser -k 4001/tcp 2>/dev/null; sleep 1 && bun run build && (bun run dev:all &)",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@node-rs/argon2": "^2.0.2",
    "@react-router/node": "^7",
    "@react-router/serve": "^7",
    "@types/diff": "^8.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/marked": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "codemirror": "^6.0.2",
    "diff": "^8.0.3",
    "dompurify": "^3.3.1",
    "geist": "^1.7.0",
    "isbot": "^4",
    "isomorphic-dompurify": "^2.36.0",
    "jszip": "^3.10.1",
    "marked": "^17.0.2",
    "marked-footnote": "^1.4.0",
    "nanoid": "^5.1.6",
    "react": "^19",
    "react-dom": "^19",
    "react-router": "^7",
    "reveal.js": "^6.0.1",
    "sharp": "^0.34.5",
    "turndown": "^7.2.2",
    "ws": "^8.19.0",
    "y-codemirror.next": "^0.3.5",
    "y-indexeddb": "^9.0.12",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.29",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-router/dev": "^7",
    "@tailwindcss/vite": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6",
    "vite-tsconfig-paths": "^5",
    "vitepress": "^1.6.4"
  }
}
